datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Community {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  tagline     String
  image       String
  avgPrice    String
  rentalYield String
  growth      String
  popularFor  String
  description String
  highlights  Json      // Array of strings
  driveTimes  Json      // Array of driveTime objects: { location, time }
  projects    Project[]
}

model Project {
  id                 Int        @id @default(autoincrement())
  slug               String     @unique
  name               String
  developer          String
  communityName      String
  community          Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  communityId        Int?
  location           String
  address            String?
  propertyType       String
  startingPrice      String
  handover           String
  paymentPlan        String
  image              String
  images             Json       // Array of image URLs
  description        String
  reraPermit         String
  escrowNumber       String?
  totalUnits         String
  coordinates        Json       // Coordinate object: { lat, lng }
  paymentPlanDetails Json       // Array of milestones
  unitMix            Json       // Array of unit mixes
  amenities          Json       // Array of amenities
  locationHighlights Json       // Array of drive times
  developerProfile   Json       // Developer statistics
  agent              Agent?     @relation(fields: [agentId], references: [id])
  agentId            Int?
  brochureUrl        String?
  floorPlanUrl       String?
  qrCodeUrl          String?

  @@index([communityId])
  @@index([developer])
  @@index([agentId])
}

model Lead {
  id              Int      @id @default(autoincrement())
  name            String
  email           String
  phone           String?  // Optional phone number
  password        String?  // Optional password for sign-in
  interestType    String   // 'wishlist' | 'brochure' | 'viewing' | 'guide' | 'contact'
  role            String?  // 'investor' | 'end-user'
  funding         String?  // 'cash' | 'mortgage' | 'installments'
  timeframe       String?  // 'immediate' | '3-6months' | 'exploring'
  message         String?
  projectName     String?  // Name of project they are interested in
  status          String   @default("New") // 'New' | 'Contacted' | 'Viewing Scheduled' | 'Follow-up Required' | 'Closed Won' | 'Lost'
  notes           String   @default("")
  assignedAgent   Agent?   @relation(fields: [assignedAgentId], references: [id])
  assignedAgentId Int?
  createdAt       DateTime @default(now())
  resetToken      String?
  resetExpires    DateTime?
  activities      LeadActivity[]
  dealValue       Float?
  commissionRate  Float?   @default(2.0)

  @@index([email])
  @@index([status])
  @@index([assignedAgentId])
}

model LeadActivity {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // 'NOTE' | 'STATUS_CHANGE' | 'EMAIL_SENT' | 'WHATSAPP_CLICKED' | 'CREATION'
  content   String
  agentName String?
  createdAt DateTime @default(now())
}

model Developer {
  id                Int      @id @default(autoincrement())
  slug              String   @unique
  name              String
  description       String
  completedProjects Int
  onTimeRate        String
  logoUrl           String?
}

model Agent {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  phone      String
  photoUrl   String
  role       String    // Job title/Specialty (e.g. Sales Director, Palm Jumeirah Specialist)
  projects   Project[]
  leads      Lead[]
  password   String?   // Encrypted password for CRM login
  systemRole String    @default("AGENT") // "ADMIN" or "AGENT"
  isBlocked  Boolean   @default(false)   // Block agent access
}

model Setting {
  id               Int    @id @default(1)
  guideUrl         String @default("/uploads/dubai-off-plan-investor-guide-2026.pdf")
  welcomeSubject   String @default("Welcome to Chlonestone Newsletter!")
  welcomeBody      String @default("Thank you for subscribing to the Chlonestone newsletter. You will receive immediate updates on premium off-plan launches, ROI projections, and waterfront inventory allocations in Dubai.")
  guideSubject     String @default("Download: Dubai Off-Plan Investor Guide 2026")
  guideBody        String @default("Thank you for requesting the Dubai Off-Plan Investor Guide 2026. You can download the booklet directly using this link: {{GUIDE_URL}}")
  inquirySubject   String @default("Thank you for contacting Chlonestone Real Estate")
  inquiryBody      String @default("Hello {{CLIENT_NAME}},\n\nThank you for reaching out to Chlonestone. We have received your inquiry regarding \"{{PROJECT_NAME}}\" and one of our premier real estate advisors will connect with you shortly.")
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
}


