# Database Settings (Supabase)
# DATABASE_URL: Transaction pooled connection string (usually port 6543)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Session/Direct connection string for migrations (usually port 5432)
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Client Credentials (required for storage and file uploads)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-here"

# SMTP Email Configuration
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_USER="resend"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Chlonestone <onboarding@resend.dev>"

# Next.js App configuration
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Initial Admin Seeding Configuration
# These are used by `npm run seed` or `npx prisma db seed` to provision your initial admin account
ADMIN_EMAIL="admin@chlonestone.com"
ADMIN_PASSWORD="securepassword123"
